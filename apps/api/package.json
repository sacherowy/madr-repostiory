{
  "name": "@adr/api",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --exclude \"**/*.integration.test.ts\"",
    "test:integration": "vitest run \"src/**/*.integration.test.ts\"",
    "reindex": "tsx src/scripts/reindex.ts"
  },
  "dependencies": {
    "@adr/core": "workspace:*",
    "@adr/shared": "workspace:*",
    "better-sqlite3": "^11.3.0",
    "fastify": "^4.28.1",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
