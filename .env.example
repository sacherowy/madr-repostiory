# --- Źródło prawdy ---
# Ścieżka do repozytorium ADR (pliki .md + frontmatter, wersjonowane gitem)
ADR_REPO_PATH=./data/adr-repo

# --- Projekcja (wtórna, odtwarzalna) ---
SQLITE_PATH=./data/index.sqlite

# --- Embeddingi: Gemini ---
# W Claude Code on the web działa na domyślnym poziomie sieci Trusted
# (host generativelanguage.googleapis.com jest objęty *.googleapis.com).
GEMINI_API_KEY=
GEMINI_EMBED_MODEL=text-embedding-004

# --- Auth zespołowy (OIDC) — do uzupełnienia ---
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

PORT=3000
